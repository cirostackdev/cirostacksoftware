# ─── Server ───────────────────────────────────────────────────────────────────
PORT=
NODE_ENV=
SITE_URL=
CORS_ORIGIN=

# ─── Broker ───────────────────────────────────────────────────────────────────
BROKER_URL=
BROKER_TOKEN=

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_URL=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ─── Mux (video) ──────────────────────────────────────────────────────────────
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# ─── Piston (code sandbox) ────────────────────────────────────────────────────
PISTON_API_URL=

# ─── AI (Anthropic) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
# Sender address. Use onboarding@resend.dev for testing (no domain verification needed).
# For production set your verified domain: CiroStack Academy <noreply@yourdomain.com>
EMAIL_FROM=CiroStack Academy <onboarding@resend.dev>

# ─── Meta (Facebook) Conversions API ────────────────────────────────────────
# Generate at: Business Settings > System Users > Generate Token (ads_management, ads_read permissions)
META_ACCESS_TOKEN=
# Optional: for testing events in Meta Events Manager before going live
META_TEST_EVENT_CODE=
