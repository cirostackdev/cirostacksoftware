{
  "name": "academy-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --external bcrypt --external @mapbox/node-pre-gyp --external mock-aws-s3 --external aws-sdk --external nock",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "generate:assets": "bun run scripts/generate-assets.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@aws-sdk/client-s3": "^3.582.0",
    "@aws-sdk/s3-request-presigner": "^3.582.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.30.10",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "postgres": "^3.4.4",
    "puppeteer": "^22.9.0",
    "stripe": "^15.7.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/cookie-parser": "^1.4.7",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.12.12",
    "drizzle-kit": "^0.21.4",
    "typescript": "^5.4.5"
  }
}
